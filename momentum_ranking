import os
import sys
from datetime import datetime, timedelta
import pandas as pd
import yfinance as yf
from tqdm import tqdm


def calculate_momentum_ranking(
    csv_path=r"C:\Momentum\ticker.csv",
    output_excel="momentum_ranking.xlsx",
):
    """Liest Ticker aus einer CSV-Datei, berechnet deren Performance über 1, 3, 6 und 9 Monate,

    generiert einen Gesamt-Score und gibt ein sortiertes Ranking aus.
    """
    # 1. CSV-Datei einlesen und Ticker extrahieren
    if not os.path.exists(csv_path):
        print(f"Fehler: Die Datei {csv_path} wurde nicht gefunden.")
        sys.exit(1)

    try:
        df_ticker = pd.read_csv(csv_path)
        # Flexibler Umgang mit Spaltennamen (sucht nach 'Ticker' oder nimmt die erste Spalte)
        ticker_col = (
            "Ticker" if "Ticker" in df_ticker.columns else df_ticker.columns[0]
        )
        tickers = (
            df_ticker[ticker_col].dropna().astype(str).str.strip().tolist()
        )
        # Duplikate entfernen, Reihenfolge beibehalten
        tickers = list(dict.fromkeys(tickers))
    except Exception as e:
        print(f"Fehler beim Lesen der CSV-Datei: {e}")
        sys.exit(1)

    if not tickers:
        print("Die CSV-Datei enthält keine Ticker.")
        sys.exit(1)

    # 2. Zeiträume definieren (9 Monate = 273 Tage laut Anforderung)
    today = datetime.today()
    periods = {
        "1M": today - timedelta(days=30),
        "3M": today - timedelta(days=91),
        "6M": today - timedelta(days=182),
        "9M": today - timedelta(days=273),
    }

    # Startdatum für den yfinance-Download bestimmen (Sicherheitsmarge für Wochenenden/Feiertage)
    start_date = min(periods.values()) - timedelta(days=10)

    print(f"Lade historische Daten für {len(tickers)} Ticker ab dem {start_date.strftime('%Y-%m-%d')}...")

    # 3. Effizienter Batch-Download via yfinance
    try:
        # Download aller Ticker auf einmal zur Reduzierung von API-Aufrufen
        raw_data = yf.download(
            tickers, start=start_date, end=today, group_by="ticker"
        )
    except Exception as e:
        print(f"Fehler beim Download der Daten über yfinance: {e}")
        sys.exit(1)

    results = []

    # 4. Daten verarbeiten und Performance berechnen
    # Falls nur ein Ticker geladen wurde, Struktur anpassen für einheitliche Iteration
    if len(tickers) == 1:
        single_ticker = tickers[0]
        raw_data = {single_ticker: raw_data}

    print("\nBerechne Performance-Kennzahlen...")
    for ticker in tqdm(tickers, desc="Verarbeite Ticker"):
        try:
            # Extrahiere Daten für den aktuellen Ticker
            if len(tickers) > 1:
                if ticker not in raw_data.columns.levels[0]:
                    continue
                ticker_df = raw_data[ticker].dropna(subset=["Adj Close"])
            else:
                ticker_df = raw_data.dropna(subset=["Adj Close"])

            if ticker_df.empty:
                print(f" -> Hinweis: Keine 'Adj Close' Daten für {ticker}")
                continue

            # Endpreis (aktuellster verfügbarer Kurs)
            end_price = ticker_df["Adj Close"].iloc[-1]

            # Hilfsfunktion, um den nächstgelegenen historischen Preis zu finden
            def get_historic_price(target_date):
                # Sucht den Kurs am Ziel-Datum oder den nächstfolgenden verfügbaren Handelstag
                available_dates = ticker_df.index[ticker_df.index >= target_date]
                if not available_dates.empty:
                    return ticker_df.loc[available_dates[0], "Adj Close"]
                return None

            # Kurse für die jeweiligen Startzeitpunkte abgreifen
            p_1m = get_historic_price(periods["1M"])
            p_3m = get_historic_price(periods["3M"])
            p_6m = get_historic_price(periods["6M"])
            p_9m = get_historic_price(periods["9M"])

            # Wenn ein wichtiger historischer Datenpunkt komplett fehlt, Ticker überspringen
            if any(p is None for p in [p_1m, p_3m, p_6m, p_9m]):
                print(
                    f" -> Hinweis: Unvollständige Historie für {ticker}. Übersprungen."
                )
                continue

            # Rendite-Berechnung nach Formel: ((Endpreis - Startpreis) / Startpreis) * 100
            ret_1m = ((end_price - p_1m) / p_1m) * 100
            ret_3m = ((end_price - p_3m) / p_3m) * 100
            ret_6m = ((end_price - p_6m) / p_6m) * 100
            ret_9m = ((end_price - p_9m) / p_9m) * 100

            # Gesamt-Score aggregieren
            score = ret_1m + ret_3m + ret_6m + ret_9m

            results.append(
                {
                    "Ticker": ticker,
                    "1M Performance (%)": round(ret_1m, 2),
                    "3M Performance (%)": round(ret_3m, 2),
                    "6M Performance (%)": round(ret_6m, 2),
                    "9M Performance (%)": round(ret_9m, 2),
                    "Gesamt-Score": round(score, 2),
                }
            )

        except Exception as e:
            print(f" -> Fehler beim Verarbeiten von Ticker {ticker}: {e}")
            continue

    if not results:
        print("Keine validen Daten für die Performance-Berechnung gefunden.")
        return

    # 5. DataFrame erstellen und sortieren (Höchster Score oben)
    ranking_df = pd.DataFrame(results)
    ranking_df = ranking_df.sort_values(by="Gesamt-Score", ascending=False)
    ranking_df = ranking_df.reset_index(drop=True)

    # 6. Output generieren
    # Terminal-Ausgabe
    print("\n" + "=" * 80)
    print("MOMENTUM RANKING (SORTIERT NACH GESAMT-SCORE)".center(80))
    print("=" * 80)
    print(ranking_df.to_string(index=True))
    print("=" * 80)

    # Excel-Export
    try:
        ranking_df.to_excel(output_excel, index=False)
        print(f"\nErfolgreich als Excel-Datei gespeichert: {output_excel}")
    except Exception as e:
        print(f"Fehler beim Speichern der Excel-Datei: {e}")

    return ranking_df


if __name__ == "__main__":
    calculate_momentum_ranking()
